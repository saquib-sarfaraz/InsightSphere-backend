{
  "name": "insightsphere-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "lint": "eslint .",
    "format": "prettier . --write",
    "gen:secret": "node --input-type=module -e \"import { randomBytes } from 'node:crypto'; console.log(randomBytes(48).toString('hex'))\"",
    "gen:secrets": "node --input-type=module -e \"import { randomBytes } from 'node:crypto'; console.log('JWT_ACCESS_SECRET=' + randomBytes(48).toString('hex')); console.log('JWT_REFRESH_SECRET=' + randomBytes(48).toString('hex')); console.log('COOKIE_SECRET=' + randomBytes(48).toString('hex'))\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.1",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.5",
    "pino": "^9.9.0",
    "pino-http": "^11.0.0",
    "redis": "^5.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2"
  },
  "description": "InsightSphere backend (Express + MongoDB) with auth, analytics, notifications, and settings APIs.",
  "main": "server.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
