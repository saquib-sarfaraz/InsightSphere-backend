## NOTE:
## - This file MUST contain placeholders only.
## - Never put real MongoDB Atlas URIs or JWT secrets in tracked files.
## - Create `backend/.env` locally (ignored by git) and paste real values there.

NODE_ENV=development
PORT=8080

# Comma-separated allowed origins (e.g. https://app.example.com,https://admin.example.com)
CORS_ORIGIN=http://localhost:5173

# MongoDB Atlas URI (placeholder)
MONGODB_URI=YOUR_MONGODB_ATLAS_URI

# JWT secrets (placeholders)
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_generate_random_32_chars_min
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_generate_random_32_chars_min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Cookies (placeholder)
COOKIE_SECRET=CHANGE_ME_cookie_secret_generate_random_32_chars_min
COOKIE_DOMAIN=
COOKIE_SECURE=false

# App URL (used in email links)
APP_BASE_URL=http://localhost:5173

# Rate limiting
RATE_LIMIT_GLOBAL_MAX=1200
RATE_LIMIT_AUTH_MAX=20

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=InsightSphere <no-reply@insightsphere.dev>

# Redis (optional)
REDIS_URL=
